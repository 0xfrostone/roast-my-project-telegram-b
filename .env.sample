# Telegram
TELEGRAM_BOT_TOKEN=

# Database (optional, used for long-term memory)
MONGODB_URI=

# CookMyBots AI Gateway (required)
# COOKMYBOTS_AI_ENDPOINT is a BASE URL (do NOT include /chat)
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=

# Optional controls
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2

# Runner/backpressure (optional)
CONCURRENCY=1
GLOBAL_INFLIGHT_CAP=2

# Optional (provided by platform after deploy, not required to run)
PUBLIC_BASE_URL=

# Optional output control
AI_SHORT_MAX_CHARS=1200
